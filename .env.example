# ====== Database (PostgreSQL) ======
# Nếu deploy trên Render/Railway, họ sẽ cung cấp sẵn DATABASE_URL, chỉ cần dán vào.
DATABASE_URL=postgresql://postgres:password@localhost:5432/infosec_academy

# ====== JWT ======
# Chuỗi bí mật để ký token đăng nhập. Đổi thành chuỗi ngẫu nhiên dài khi deploy thật.
JWT_SECRET=thay-doi-chuoi-bi-mat-nay-truoc-khi-deploy
JWT_EXPIRES_IN=7d

# ====== Server ======
PORT=4000
NODE_ENV=development
# Domain frontend được phép gọi API (CORS). Khi deploy, đổi thành domain thật.
FRONTEND_URL=http://localhost:5173

# ====== AI (Anthropic Claude API) ======
# Lấy API key tại https://console.anthropic.com/
# Để trống nếu chưa có key — hệ thống sẽ tự dùng nội dung giải thích có sẵn (offline).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
